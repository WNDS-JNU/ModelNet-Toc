# LobeHub ToC pilot
LOBE_PORT=3081
LOBE_REPLICAS=1
LOBE_IMAGE=modelnet/lobehub-toc:2.2.0-modelnet
LOBEHUB_TOC_SRC=./lobehub
APP_URL=http://YOUR_SERVER_IP:3081
INTERNAL_APP_URL=http://localhost:3210

# Generate with:
#   openssl rand -base64 32
KEY_VAULTS_SECRET=replace-with-random-base64
AUTH_SECRET=replace-with-random-base64

# Generate an RSA JWK for LobeHub auth. Do not commit production values.
JWKS_KEY={"keys":[]}

# Database
LOBE_DB_NAME=lobechat
POSTGRES_PASSWORD=replace-with-random-password

# RustFS / S3-compatible storage
S3_ENDPOINT=http://YOUR_SERVER_IP:9100
RUSTFS_PORT=9100
RUSTFS_ADMIN_PORT=9101
RUSTFS_ACCESS_KEY=admin
RUSTFS_SECRET_KEY=replace-with-random-secret
RUSTFS_LOBE_BUCKET=lobe

# ToC pilot defaults
AUTH_DISABLE_EMAIL_PASSWORD=0
ENABLED_OPENAI=1
ENABLED_OLLAMA=0

# ModelNet gateway
# MODELNET_LITELLM_API_KEY protects the internal LiteLLM OpenAI-compatible proxy used by LobeHub.
# MODELNET_BACKEND_API_KEY is forwarded to backend OpenAI-compatible model servers; use "none" when they do not require auth.
MODELNET_LITELLM_API_KEY=replace-with-random-api-key
MODELNET_BACKEND_API_KEY=none
